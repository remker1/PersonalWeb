# Copy to .env.local for local dev. For Vercel, set these in Project → Settings → Environment Variables.

# Supabase (frontend – used by Vite at build time and in browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase + Admin (serverless /api/admin – only on Vercel server)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ADMIN_PASSWORD=your-admin-password
